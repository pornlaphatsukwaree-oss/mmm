<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
  </head>
  <body>
    <!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>Circus Arena</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: linear-gradient(135deg, #1e0b36 0%, #080214 100%);
            min-height: 100vh;
            font-family: system-ui, -apple-system, sans-serif;
        }
        .tent-stripes {
            background: repeating-linear-gradient(45deg, #dc2626, #dc2626 30px, #ffffff 30px, #ffffff 60px);
            border-bottom: 6px solid #f59e0b;
        }
    </style>
</head>
<body class="text-white pb-12">

    <header class="tent-stripes w-full py-8 text-center shadow-xl relative">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-10">
            <h1 class="text-4xl md:text-6xl font-black text-amber-400 tracking-wider">🎪 the 100th Midnight Circus  🎪</h1>
            <h1 class="text-4xl md:text-6xl font-black text-amber-400 tracking-wider">  curse of the Marionettes  </h1>
            <p class="text-amber-100 text-sm md:text-base mt-2">100 ปี มหรสพรัตติกาล : อาถรรพ์คำสาปหุ่นเชิดแห่งหกเต็นท์ปริศนา</p>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 mt-8">
        
        <div class="flex justify-between items-center mb-6 bg-white/5 p-4 rounded-xl border border-white/10">
            <div class="text-xs text-emerald-400 flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span> ระบบทำงานปกติ
            </div>
            <button onclick="resetScores()" class="bg-red-600 hover:bg-red-700 text-white text-sm font-bold py-2 px-4 rounded-lg transition active:scale-95">
                🔄 รีเซ็ตคะแนนทั้งหมด
            </button>
        </div>

        <div id="leaderboard" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            </div>

    </main>

    <script>
        // ข้อมูลของทั้ง 6 ทีมละครสัตว์
        let teams = [
            { id: 1, name: "Ringmasters", icon: "🎩", score: 0, color: "from-orange-500 to-amber-600" },
            { id: 2, name: "Acrobats", icon: "🤸🏻", score: 0, color: "from-blue-500 to-indigo-600" },
            { id: 3, name: "Magicians", icon: "🎭", score: 0, color: "from-pink-500 to-rose-600" },
            { id: 4, name: "Fire Eaters", icon: "🔥", score: 0, color: "from-purple-600 to-indigo-900" },
            { id: 5, name: "Jugglers", icon: "🤹🏻", score: 0, color: "from-teal-500 to-emerald-600" },
            { id: 6, name: "Joker Clowns", icon: "🤡", score: 0, color: "from-yellow-500 to-amber-600" }
        ];

        const STORAGE_KEY = 'circus_scores_gas_v2';

        // โหลดคะแนนเก่าจากบราวเซอร์เครื่องที่เปิด
        if (localStorage.getItem(STORAGE_KEY)) {
            try {
                let saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
                teams.forEach(t => { if(saved[t.id] !== undefined) t.score = saved[t.id]; });
            } catch(e) { console.log(e); }
        }

        // ฟังก์ชันบวก/ลบคะแนน
        function updateScore(id, amount) {
            let team = teams.find(t => t.id === id);
            if (team) {
                team.score = Math.max(0, team.score + amount); // ไม่ให้ติดลบ
                localStorage.setItem(STORAGE_KEY, JSON.stringify(Object.fromEntries(teams.map(t => [t.id, t.score]))));
                render();
            }
        }

        // ฟังก์ชันล้างคะแนนทั้งหมด
        function resetScores() {
            if (confirm("คุณแน่ใจใช่ไหมว่าจะรีเซ็ตแต้มทุกทีมให้เป็น 0?")) {
                teams.forEach(t => t.score = 0);
                localStorage.removeItem(STORAGE_KEY);
                render();
            }
        }

        // ฟังก์ชันวาดหน้าจอและการจัดอันดับแบบอัตโนมัติ
        function render() {
            let board = document.getElementById('leaderboard');
            board.innerHTML = '';

            // เรียงลำดับคะแนนจากมากไปน้อย
            let sorted = [...teams].sort((a, b) => b.score - a.score);

            sorted.forEach((team, index) => {
                let rank = index + 1;
                let badge = `<span class="bg-black/30 px-2 py-0.5 rounded text-xs">อันดับ ${rank}</span>`;
                if (rank === 1 && team.score > 0) badge = `<span class="bg-yellow-400 text-black px-2 py-0.5 rounded text-xs font-bold">👑 ที่ 1</span>`;

                board.innerHTML += `
                    <div class="bg-gradient-to-br ${team.color} p-6 rounded-2xl shadow-lg border border-white/10 relative flex flex-col justify-between">
                        <div class="absolute top-4 right-4">${badge}</div>
                        
                        <div class="flex items-center gap-3 mt-2">
                            <span class="text-4xl">${team.icon}</span>
                            <h3 class="text-lg font-bold">${team.name}</h3>
                        </div>

                        <div class="my-4 bg-black/20 rounded-xl py-3 text-center">
                            <span class="text-5xl font-black text-amber-300">${team.score}</span>
                            <span class="text-xs text-white/60 block mt-1">คะแนนสะสม</span>
                        </div>

                        <div class="space-y-2">
                            <div class="grid grid-cols-3 gap-1.5">
                                <button onclick="updateScore(${team.id}, 1)" class="bg-white/20 hover:bg-white/30 text-xs font-bold py-2 rounded-lg">+1</button>
                                <button onclick="updateScore(${team.id}, 5)" class="bg-white/20 hover:bg-white/30 text-xs font-bold py-2 rounded-lg">+5</button>
                                <button onclick="updateScore(${team.id}, 10)" class="bg-yellow-400 hover:bg-yellow-300 text-black text-xs font-black py-2 rounded-lg">+10</button>
                            </div>
                            <div class="grid grid-cols-3 gap-1.5 opacity-40 hover:opacity-100 transition">
                                <button onclick="updateScore(${team.id}, -1)" class="bg-black/40 hover:bg-black/60 text-[10px] py-1 rounded-lg">-1</button>
                                <button onclick="updateScore(${team.id}, -5)" class="bg-black/40 hover:bg-black/60 text-[10px] py-1 rounded-lg">-5</button>
                                <button onclick="updateScore(${team.id}, -10)" class="bg-red-900/40 hover:bg-red-900/60 text-red-200 text-[10px] py-1 rounded-lg">-10</button>
                            </div>
                        </div>
                    </div>
                `;
            });
        }
// ⏱️ กลไกเช็กข้อมูลใหม่แบบอัจฉริยะ คอยคุยกับเซิร์ฟเวอร์ดึงค่าใหม่ของทุกคนลงบอร์ดทุกๆ 2 วินาที (2000 ms)
        setInterval(checkRealtimeUpdates, 2000);
    </script>
        // สั่งให้วาดหน้าจอครั้งแรก
        render();
    </script>
</body>
</html>
  </body>
</html>
