<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Circus Point Arena - ระบบคะแนนเรียลไทม์</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mitr:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Mitr', sans-serif; background: radial-gradient(circle, #2b1055, #100520); min-height: 100vh; }
        .circus-title { font-family: 'Playfair Display', 'Mitr', serif; text-shadow: 3px 3px 0px #d62828, 6px 6px 0px #003049; }
        .circus-tent-header { background: repeating-linear-gradient(45deg, #e63946, #e63946 30px, #ffffff 30px, #ffffff 60px); border-bottom: 8px solid #fcbf49; }
        .gold-glow { box-shadow: 0 0 25px #fcbf49; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.02); } 100% { transform: scale(1); } }
    </style>
</head>
<body class="text-white pb-12">
    <div class="circus-tent-header w-full py-6 text-center shadow-2xl relative overflow-hidden">
        <div class="bg-black/40 absolute inset-0 backdrop-blur-[1px]"></div>
        <div class="relative z-10">
            <h1 class="circus-title text-5xl md:text-6xl font-bold text-[#fcbf49] tracking-wider uppercase italic">🎪 CIRCUS ARENA 🎪</h1>
            <p class="text-white text-lg md:text-xl font-light mt-2 tracking-wide drop-shadow-md">ระบบคำนวณคะแนนและจัดอันดับคณะละครสัตว์สุดมหัศจรรย์</p>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 mt-10">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
            <div class="text-xs text-amber-300 bg-white/5 px-4 py-2 rounded-full border border-white/10 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
                <span id="sync-status">กำลังเชื่อมต่อระบบเรียลไทม์...</span>
            </div>
            <button onclick="resetScores()" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-6 rounded-full shadow-lg transition duration-300 transform hover:scale-105 flex items-center gap-2 border-2 border-white/20">🔄 รีเซ็ตคะแนนทั้งหมด</button>
        </div>

        <div id="leaderboard" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-500"></div>
    </div>
    
    <div class="text-center mt-12 text-white/40 text-sm">✨ ยินดีต้อนรับสู่โลกแห่งความสุขและการแข่งขันที่ยุติธรรม ✨</div>

    <script>
        // 🔗 ลิงก์ตรงหลังบ้าน Google Apps Script ล่าสุดของคุณ
        const GAS_WEBAPP_URL = "https://script.google.com/macros/s/AKfycbxavqFIs57TQM5Pw_5U6baAUJYyRiaY4sW672TOBJ2ZIBhKpX19K_Bn-nXhxW1gr5Amyg/exec";

        // โครงสร้างข้อมูลทีม
        let teams = [
            { id: 1, name: "ทีมสิงโตเจ้าปัญญา", icon: "🦁", score: 0, color: "from-orange-500 to-amber-600", border: "border-orange-400" },
            { id: 2, name: "ทีมช้างน้อยกายกรรม", icon: "🐘", score: 0, color: "from-blue-500 to-indigo-600", border: "border-blue-400" },
            { id: 3, name: "ทีมตัวตลกโบโซ่", icon: "🤡", score: 0, color: "from-pink-500 to-rose-600", border: "border-pink-400" },
            { id: 4, name: "ทีมมายากลลึกลับ", icon: "🎩", score: 0, color: "from-purple-600 to-indigo-900", border: "border-purple-400" },
            { id: 5, name: "ทีมโลดโผนเวหา", icon: "🎪", score: 0, color: "from-teal-500 to-emerald-600", border: "border-teal-400" },
            { id: 6, name: "ทีมลิงจอมซน", icon: "🐒", score: 0, color: "from-yellow-500 to-amber-600", border: "border-yellow-400" }
        ];

        // ฟังก์ชันอัปเดตแต้มบนหน้าจอคอมพิวเตอร์หลังได้รับข้อมูลจากเซิร์ฟเวอร์
        function handleScores(scoreMap) {
            if(!scoreMap || typeof scoreMap !== 'object') return;
            teams.forEach(t => { if(scoreMap[t.id] !== undefined) t.score = scoreMap[t.id]; });
            document.getElementById('sync-status').innerText = "ซิงค์ออนไลน์ล่าสุด: " + new Date().toLocaleTimeString('th-TH');
            renderLeaderboard();
        }

        // ดึงคะแนนล่าสุดจาก Google Sheets
        async function checkRealtimeUpdates() {
            try {
                let res = await fetch(GAS_WEBAPP_URL);
                let data = await res.json();
                handleScores(data);
            } catch (err) { console.log("กำลังรอการเชื่อมต่อฐานข้อมูล..."); }
        }

        // กดปุ่มบวก/ลบคะแนน
        async function updateScore(teamId, amount) {
            const team = teams.find(t => t.id === teamId);
            if (team) team.score = Math.max(0, team.score + amount);
            renderLeaderboard();
            document.getElementById('sync-status').innerText = "กำลังบันทึกข้อมูลลงฐานข้อมูลคลาวด์...";
            try {
                let res = await fetch(GAS_WEBAPP_URL, {
                    method: 'POST',
                    body: JSON.stringify({ teamId: teamId, amount: amount })
                });
                let data = await res.json();
                handleScores(data);
            } catch (err) { console.error(err); }
        }

        // สั่งล้างคะแนนเป็น 0
        async function resetScores() {
            if (confirm("คุณแน่ใจใช่ไหมว่าจะล้างแต้มของทุกทีมให้เป็น 0 บนคลาวด์?")) {
                document.getElementById('sync-status').innerText = "กำลังรีเซ็ตฐานข้อมูล...";
                try {
                    let res = await fetch(GAS_WEBAPP_URL, { 
                        method: 'POST', 
                        body: JSON.stringify({ action: 'reset' }) 
                    });
                    let data = await res.json();
                    handleScores(data);
                } catch (err) { console.error(err); }
            }
        }

        // แสดงผลการจัดอันดับแบบไดนามิก (ทีมไหนแต้มเยอะสุดจะเด้งขึ้นอันดับ 1 อัตโนมัติ)
        function renderLeaderboard() {
            const leaderboardEl = document.getElementById('leaderboard');
            leaderboardEl.innerHTML = '';
            const sortedTeams = [...teams].sort((a, b) => b.score - a.score);
            const highestScore = Math.max(...teams.map(t => t.score));
            sortedTeams.forEach((team, index) => {
                const isFirst = team.score > 0 && team.score === highestScore;
                const rankNumber = index + 1;
                let rankBadge = `<span class="bg-black/30 px-3 py-1 rounded-full text-sm font-bold">อันดับ ${rankNumber}</span>`;
                if (rankNumber === 1 && team.score > 0) rankBadge = `👑 <span class="bg-amber-400 text-black px-3 py-1 rounded-full text-sm font-bold">ผู้นำคะแนน</span>`;
                if (rankNumber === 2 && team.score > 0) rankBadge = `🥈 <span class="bg-slate-300 text-black px-3 py-1 rounded-full text-sm font-bold">อันดับ 2</span>`;
                if (rankNumber === 3 && team.score > 0) rankBadge = `🥉 <span class="bg-amber-700 text-white px-3 py-1 rounded-full text-sm font-bold">อันดับ 3</span>`;
                leaderboardEl.innerHTML += `
                    <div class="bg-gradient-to-br ${team.color} rounded-3xl p-6 shadow-xl border-4 ${team.border} relative transition-all duration-500 transform hover:-translate-y-1 ${isFirst ? 'gold-glow z-10' : ''}">
                        <div class="absolute top-4 right-4 flex items-center gap-1">${rankBadge}</div>
                        <div class="flex items-center gap-4 mt-2">
                            <span class="text-5xl drop-shadow-md">${team.icon}</span>
                            <div>
                                <h3 class="text-xl font-bold tracking-wide text-white drop-shadow-md">${team.name}</h3>
                                <p class="text-xs text-white/70">คณะละครสัตว์อัศจรรย์</p>
                            </div>
                        </div>
                        <div class="my-6 bg-black/20 rounded-2xl py-4 text-center border border-white/10">
                            <span class="text-sm block uppercase tracking-widest text-white/60 mb-1">คะแนนสะสม</span>
                            <span class="text-5xl font-bold text-[#fcbf49] font-mono drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">${team.score.toLocaleString()}</span>
                            <span class="text-sm text-white/80 ml-1">แต้ม</span>
                        </div>
                        <div class="space-y-3">
                            <div class="grid grid-cols-3 gap-2">
                                <button onclick="updateScore(${team.id}, 10)" class="bg-white/20 hover:bg-white/30 text-white font-semibold py-2 px-1 rounded-xl text-sm transition active:scale-95">+10</button>
                                <button onclick="updateScore(${team.id}, 50)"
